# This repo isn't itself a Unity project; ignore the self-generated brain.
.unity-vibe/
# In real Unity projects you may want to commit project_brain.* and conventions.md
# and only ignore the volatile bits below:
# .unity-vibe/snapshots/
# .unity-vibe/runtime_logs/
# .unity-vibe/asset_index.sqlite
# .unity-vibe/trash/
Library/
Temp/
Logs/
UserSettings/
*.log
# Tauri desktop app (apps/desktop) build output. `dist/` above already covers
# the Vite bundle; these cover the Rust target dir and generated schemas.
apps/desktop/src-tauri/target/
apps/desktop/src-tauri/gen/schemas/

# Vendored binaries — fetched by `pnpm --filter @uvibe/desktop bundle`, never
# committed. The offline dictation model + ONNX runtime are ~80MB of weights;
# `bundle:whisper` re-fetches them reproducibly.
apps/desktop/public/models/
apps/desktop/public/ort/
apps/desktop/src-tauri/binaries/
apps/desktop/src-tauri/resources/
