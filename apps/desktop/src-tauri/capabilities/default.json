{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for the Unity Vibe Studio main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:default",
    "core:window:allow-start-dragging",
    "dialog:default",
    "dialog:allow-open",
    "opener:default",
    "opener:allow-open-url",
    "opener:allow-reveal-item-in-dir"
  ]
}
